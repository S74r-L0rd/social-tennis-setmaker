# Copy this file to server/.env and fill in your values

# PostgreSQL connection string
# Local: postgresql://postgres:YOUR_PASSWORD@localhost:5432/tennis_setmaker?schema=public
# Neon:  postgresql://USERNAME:PASSWORD@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USERNAME:PASSWORD@HOST:5432/DATABASE_NAME?schema=public"

# JWT secret — change this to any long random string in production
JWT_SECRET="change-this-to-a-long-random-string"

# JWT token expiry
JWT_EXPIRES_IN="7d"

# Allowed frontend origin for CORS (default: http://localhost:5173)
CLIENT_URL="http://localhost:5173"